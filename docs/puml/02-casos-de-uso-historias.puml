@startuml
title LifeDuo - Casos de Uso e Historias de Usuario
left to right direction

actor "Parceiro" as Partner
actor "Administrador" as Admin
actor "Gateway de Pagamento" as Payment
actor "FCM" as FCM

rectangle "LifeDuo" {
  usecase "UC-01\nRealizar check-in diario" as UC1
  usecase "UC-02\nGerenciar meta compartilhada" as UC2
  usecase "UC-03\nEnviar presente digital" as UC3
  usecase "UC-04\nAcompanhar evolucao do mascote" as UC4
  usecase "UC-05\nReceber notificacoes" as UC5
  usecase "UC-06\nModerar conteudo" as UC6
}

Partner --> UC1
Partner --> UC2
Partner --> UC3
Partner --> UC4
Partner --> UC5
Admin --> UC6
Payment --> UC3
FCM --> UC5

note bottom
HU-01: Como casal, queremos registrar humor diario para manter streak.
HU-02: Como casal, queremos metas com progresso para planejar juntos.
HU-03: Como usuario, quero enviar gift card surpresa no Gift Center.
end note
@enduml

