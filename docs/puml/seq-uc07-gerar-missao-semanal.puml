@startuml
skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam sequenceArrowThickness 1.5
skinparam sequenceParticipantBorderColor #C2185B
skinparam sequenceParticipantBackgroundColor #F8BBD0
skinparam sequenceActorBorderColor #C2185B
skinparam sequenceActorBackgroundColor #F48FB1
skinparam sequenceLifeLineBorderColor #AD1457
skinparam sequenceArrowColor #880E4F
skinparam ArrowColor #880E4F
skinparam noteBorderColor #AD1457
skinparam noteBackgroundColor #FCE4EC
skinparam noteFontColor #880E4F
skinparam sequenceMessageFontColor #880E4F
skinparam databaseBorderColor #C2185B
skinparam databaseBackgroundColor #F8BBD0
skinparam collectionsBackgroundColor #F8BBD0
skinparam collectionsBorderColor #C2185B

autonumber
title UC-07 - Sequência Gerar Missão Semanal

actor "Scheduler (Cron)" as Cron
participant "MissionJob (BullMQ)" as Job
participant "MissionFactory" as Factory
participant "MissionService" as Service
database "PostgreSQL" as DB
participant "NotificationService" as Notification
participant "FCM" as FCM

Cron -> Job : dispararFilaSemanal()
activate Job
Job -> Factory : criarMissao(tipoSemana)
activate Factory
Factory --> Job : Missao(template)
deactivate Factory

Job -> Service : atribuirMissaoAoCasal(missao)
activate Service
Service -> DB : salvarMissao(missao)
activate DB
DB --> Service : persistido
deactivate DB
Service -> Notification : notificarNovaMissao(casalId, missao)
activate Notification
Notification -> FCM : push("Nova missão da semana")
FCM --> Notification : entregue
deactivate Notification

Job --> Cron : concluido
deactivate Job

note right of Service
  CO-07 — Pós-condições:
  missões geradas e atribuídas; notificações enviadas.
end note

@enduml