@startuml
skinparam StateBackgroundColor #F8BBD0
skinparam StateBorderColor #C2185B
skinparam ArrowColor #880E4F
skinparam StateEndColor #AD1457
skinparam StateStartColor #C2185B
skinparam FontName Arial

title UC-04 - Mascote Virtual\nDiagrama de Estados

[*] --> Neutro

state "Neutro" as Neutro {
  Neutro : humor = "neutro"
  Neutro : xpMultiplier = 1.0
  Neutro : animacao = "padrão"
}

Neutro --> Feliz : [both_checkin]\nincrementarXP(5)\natualizarHumor()

state "Feliz" as Feliz {
  Feliz : humor = "feliz"
  Feliz : xpMultiplier = 1.2
  Feliz : animacao = "contente"
}

Feliz --> Empolgado : [meta_concluida or presente_recebido]\naplicarBonusXP(20)\nativarAnimacaoEspecial()

Feliz --> Triste : [inatividade > 48h]\nreduzirXP(daily)\nmudaAnimacao()

state "Empolgado" as Empolgado {
  Empolgado : humor = "empolgado"
  Empolgado : xpMultiplier = 1.5
  Empolgado : animacao = "celebração"
}

Empolgado --> Feliz : [tempo_passado >= 24h]\nreduzirEuforia()

state "Triste" as Triste {
  Triste : humor = "triste"
  Triste : xpMultiplier = 0.5
  Triste : animacao = "alerta"
}

Triste --> Neutro : [novo_checkin]\nrestaurarHumor()

Triste --> Congelado : [usar_streak_freeze]\nconservarStreak()\nativarProtecao()

state "Congelado" as Congelado {
  Congelado : humor = "protegido"
  Congelado : streakProtegido = true
  Congelado : dataExpiracao = setada
}

Congelado --> Neutro : [freeze_expira]\nliberarProtecao()

state "Customizando" as Customizando {
  Customizando : emCustomizacao = true
  Customizando : opcoesSelecionadas = carregadas
}

Neutro --> Customizando : [abrir_customizacao]\ncarregarOpcoes()

Customizando --> Neutro : [salvar_customizacao]\npersistirAparencia()\natualizarVisual()

state "Doente" as Doente {
  Doente : humor = "doente"
  Doente : xpMultiplier = 0.0
  Doente : restricoes = ativas
}

Neutro --> Doente : [registrar_saude and severidade >= 3]\naplicarRestricoes()\nmodificarFuncionalidades()

Doente --> Neutro : [melhora]\nremoverRestricoes()\nrecuperarFuncoes()

state "RecebePresente" as RecebePresente {
  RecebePresente : emAnimacao = true
  RecebePresente : presentesRecebidos = []
}

Neutro --> RecebePresente : [presente_recebido]\nanimarSurpresa()\nadicionarXP(10)

RecebePresente --> Feliz : [animacao_concluida]\nconfirmarRecebimento()\nativarFelicidade()

note as LegendaMascote
  **Estados principais:**
  • Neutro: estado base (xpMultiplier = 1.0)
  • Feliz: após check-in dos dois (xpMultiplier = 1.2)
  • Empolgado: prêmios/marcos (xpMultiplier = 1.5)
  • Triste: inatividade > 48h (xpMultiplier = 0.5, alerta)
  • Congelado: proteção de streak ativa
  • Doente: registro saúde severo (restrições)
  • Customizando: seleção de roupas/acessórios
  • RecebePresente: animação de surpresa
  
  **Transições principais:**
  • [both_checkin] → Feliz
  • [meta_concluida or presente_recebido] → Empolgado
  • [inatividade > 48h] → Triste
  • [novo_checkin] → Neutro
  • [usar_streak_freeze] → Congelado
end note

@enduml