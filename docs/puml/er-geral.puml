@startuml
title Modelo Entidade-Relacionamento (E-R) - LifeDuo

skinparam backgroundColor #FAFAFA
skinparam shadowing false
skinparam ArrowColor #880E4F
skinparam linetype ortho
skinparam entityBorderColor #C2185B
skinparam entityBackgroundColor #FCE4EC
skinparam entityFontColor #880E4F

left to right direction

entity "Couple" as Couple {
  *id : UUID <<PK>>
  createdAt : DateTime
}

entity "Partner" as Partner {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  name : String
  email : String
}

entity "CheckIn" as CheckIn {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  partnerId : UUID <<FK>>
  mood : String
  createdAt : DateTime
}

entity "Streak" as Streak {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  countDays : Int
  isProtected : Boolean
  freezeExpiresAt : DateTime
}

entity "Pet" as Pet {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  level : Int
  xp : Int
  mood : String
  skinId : String
}

entity "Achievement" as Achievement {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  title : String
  unlockedAt : DateTime
}

entity "Mission" as Mission {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  status : String
  dueAt : DateTime
  xpAwarded : Int
}

entity "Goal" as Goal {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  title : String
  targetValue : Decimal
  progress : Decimal
  status : String
}

entity "Note" as Note {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  content : Text
  type : String
  isShared : Boolean
}

entity "WishlistItem" as WishlistItem {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  itemName : String
  isPurchased : Boolean
}

entity "Gift" as Gift {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  giftType : String
  message : String
  status : String
  sentAt : DateTime
}

entity "SpecialDate" as SpecialDate {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  title : String
  date : Date
  alertDaysBefore : Int
}

entity "Place" as Place {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  name : String
  latitude : Decimal
  longitude : Decimal
  visited : Boolean
}

entity "PlaceMemory" as PlaceMemory {
  *id : UUID <<PK>>
  placeId : UUID <<FK>>
  photoUrl : String
  note : String
  createdAt : DateTime
}

entity "WellnessRecord" as WellnessRecord {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  type : String
  dataEncrypted : String
  consent : Boolean
}

entity "RealPet" as RealPet {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  name : String
  species : String
  birthDate : Date
}

entity "Notification" as Notification {
  *id : UUID <<PK>>
  coupleId : UUID <<FK>>
  type : String
  payloadJson : JSON
  isRead : Boolean
  sentAt : DateTime
}

entity "ContentReport" as ContentReport {
  *id : UUID <<PK>>
  reporterId : UUID <<FK>>
  contentId : UUID
  reason : String
  status : String
  reviewedAt : DateTime
}

' Couple no centro
Couple ||--o{ Partner : "possui"
Couple ||--o{ CheckIn : "registra"
Partner ||--o{ CheckIn : "realiza"
Couple ||--|| Streak : "mantém"
Couple ||--|| Pet : "possui"
Couple ||--o{ Achievement : "desbloqueia"
Couple ||--o{ Mission : "cumpre"
Couple ||--o{ Goal : "cria"
Couple ||--o{ Note : "escreve"
Couple ||--o{ WishlistItem : "deseja"
Couple ||--o{ Gift : "envia"
Couple ||--o{ SpecialDate : "celebra"
Couple ||--o{ Place : "salva"
Place ||--o{ PlaceMemory : "gera"
Couple ||--o{ WellnessRecord : "registra"
Couple ||--|| RealPet : "possui"
Couple ||--o{ Notification : "recebe"
Partner ||--o{ ContentReport : "reporta"

@enduml